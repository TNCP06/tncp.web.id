# ── Payload CMS ──
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=
# SQLite file. Prod: file:/data/tncp.db (Docker volume). Local dev: file:./data/tncp.db
DATABASE_URI=file:./data/tncp.db
# Media upload dir. Prod: /data/media (Docker volume). Local dev: ./data/media
MEDIA_DIR=./data/media

# ── Site ──
SITE_URL=https://tncp.web.id
# Blog URL — empty until Phase 2 (empty hides the Blog button)
NEXT_PUBLIC_BLOG_URL=

# ── Contact notifications ──
# A new contact message is delivered to the owner over BOTH channels at once
# (email + Telegram). Each channel activates only when its vars are set;
# leaving a block empty silently skips that channel.
# Telegram (reuse a bot token; CONTACT_TG_CHAT_ID is your personal chat id):
TG_BOT_TOKEN=
CONTACT_TG_CHAT_ID=
# Optional: self-hosted bot-api base. Defaults to https://api.telegram.org
TG_API=
# Email over SMTP (without SMTP_HOST, email is skipped / console-mocked in dev):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Where notifications land; defaults to SMTP_FROM, then SMTP_USER
CONTACT_EMAIL_TO=

# ── Blog ingest (Personal-Assistant-AI → blog) ──
# Shared secret the content bot sends as `Authorization: Bearer <value>` to /api/ingest/*
INGEST_SECRET=

NODE_ENV=development
